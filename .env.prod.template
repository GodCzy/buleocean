# BlueOcean production environment template
# Copy this file to `.env.prod` before running:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod config
#
# Do not commit real secrets.

# Core runtime
HOST_IP=
TZ=Asia/Shanghai

# Database defaults (Phase 7 canonical naming)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=blueocean_know
POSTGRES_URL=postgresql+asyncpg://postgres:change_me@postgres:5432/blueocean_know

# Cache
REDIS_URL=redis://redis:6379/0

# Graph
NEO4J_URI=bolt://graph:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me

# Milvus / MinIO
MILVUS_URI=http://milvus:19530
MILVUS_DB_NAME=default
MILVUS_TOKEN=
MINIO_URI=http://milvus-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Service endpoints
MINERU_VL_SERVER=http://mineru-vllm-server:30000
MINERU_API_URI=http://mineru-api:30001
PADDLEX_URI=http://paddlex:8080

# App behavior
RUN_EVENTS_STREAM_TTL_SECONDS=7200
RUN_CANCEL_KEY_TTL_SECONDS=1800
RUNNING_IN_DOCKER=true
MODEL_DIR_IN_DOCKER=/models
VITE_USE_RUNS_API=false
